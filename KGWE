function StartAntiBlock1()
    if AntiBlockConn then AntiBlockConn:Disconnect() end
    AntiBlockConn = RunService.Stepped:Connect(function()
        pcall(function()
            for _, otherPlayer in pairs(Players:GetPlayers()) do
                if otherPlayer ~= lp and otherPlayer.Character then
                    for _, part in pairs(otherPlayer.Character:GetDescendants()) do
                        if part:IsA("BasePart") and part.CanCollide then part.CanCollide = false end
                    end
                end
            end
        end)
    end)
end

-- [FUNGSI UTAMA: GLOBAL AGAR BISA DIBACA TAB 6]
-- Menghilangkan 'local' agar fungsi ini bersifat global
function ApplyPreset1(data)
    -- Logika Penanganan Data: 
    -- Jika data adalah table (dari Tab 6/Saved List), ambil isinya. Jika angka, gunakan langsung.
    local targetId = nil
    if type(data) == "table" then
        targetId = tonumber(data.Data) or tonumber(data[1]) or data.ID
    else
        targetId = tonumber(data)
    end

    if not targetId then return false end

    local char = lp.Character or lp.CharacterAdded:Wait()
    local hum = char:WaitForChild("Humanoid", 5)
    
    if hum then
        local success, desc = pcall(function() return Players:GetHumanoidDescriptionFromUserIdAsync(targetId) end)
        if success and desc then
            -- Bersihkan Item Lama agar tidak bertumpuk (Sesuai Logika Master)
            for _, v in pairs(char:GetChildren()) do 
                if v:IsA("Accessory") or v:IsA("Shirt") or v:IsA("Pants") or v:IsA("CharacterMesh") or v:IsA("BodyColors") then 
                    v:Destroy() 
                end 
            end
            
            pcall(function()
                hum:ApplyDescriptionClientServer(desc)
            end)
            
            StartAntiBlock1()
            LastAppliedID1 = targetId
            return true
        end
    end
    return false
end

-- [FUNGSI RESET]
function ResetToOriginal1()
    LastAppliedID1 = nil
    if AntiBlockConn then AntiBlockConn:Disconnect(); AntiBlockConn = nil end
    local success, desc = pcall(function() return Players:GetHumanoidDescriptionFromUserIdAsync(lp.UserId) end)
    if success then
        local char = lp.Character
        if char and char:FindFirstChild("Humanoid") then
            char.Humanoid:ApplyDescriptionClientServer(desc)
        end
    end
end

-- Daftarkan ke Global Table (Untuk Backup Tab 6)
_G.ApplyPreset1 = ApplyPreset1

