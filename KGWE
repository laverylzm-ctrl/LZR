	end
end

SliderContainer.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then isSliding = true end end)
UserInputService.InputChanged:Connect(function(input)
	if isSliding and input.UserInputType == Enum.UserInputType.MouseMovement then
		local pos = math.clamp((input.Position.X - SliderFrame.AbsolutePosition.X) / SliderFrame.AbsoluteSize.X, 0, 1)
		currentTrans = pos; SliderDot.Position = UDim2.new(pos, 0, 0.5, 0); SliderBar.Size = UDim2.new(pos, 0, 1, 0)
		if isMinimized then MainFrame.BackgroundTransparency = currentTrans end
	end
end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then isSliding = false end end)

MainFrame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 and not isSliding then
		local pressStartTime = tick(); local hasMoved = false; dragStart = input.Position; startPos = MainFrame.Position
		local moveConn; moveConn = UserInputService.InputChanged:Connect(function(moveInput)
			if moveInput.UserInputType == Enum.UserInputType.MouseMovement then
				local delta = moveInput.Position - dragStart
				if delta.Magnitude > 5 then
					hasMoved = true; dragging = true
					MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
				end
			end
		end)
		local endConn; endConn = input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				moveConn:Disconnect(); endConn:Disconnect()
				if isMinimized and (tick() - pressStartTime) < 0.25 and not hasMoved then ToggleMinimize(false) end
				dragging = false
			end
		end)
	end
end)

