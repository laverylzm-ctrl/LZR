local function SafeWrite(name, content)
    if writefile then pcall(function() writefile(name, content) end) end
end

local function SafeRead(name)
    if isfile and isfile(name) then
        local s, res = pcall(function() return readfile(name) end)
        return s and res or nil
    end
    return nil
end

local function UpdateLabelName(idText, label, defaultName)
    local id = tonumber(idText:match("%d+"))
    if not id then label.Text = defaultName; label.TextColor3 = Color3.new(0.7,0.7,0.7) return end
    task.spawn(function()
        local success, info = pcall(function() return MarketplaceService:GetProductInfo(id) end)
        if success and info then
            label.Text = info.Name:sub(1,14)
            label.TextColor3 = Color3.fromRGB(100, 200, 255)
        end
    end)
end

local function AlignSmart(acc, char)
    local handle = acc:FindFirstChild("Handle")
    if not handle then return end
    local att = handle:FindFirstChildOfClass("Attachment")
    local targetPart, charAtt
    if att then
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("Attachment") and v.Name == att.Name then charAtt = v; targetPart = v.Parent; break end
        end
    end
    targetPart = targetPart or char:FindFirstChild("Head")
    if not targetPart then return end
    handle.CanCollide = false
    acc.Parent = char
    for _, w in pairs(handle:GetChildren()) do if w:IsA("Weld") or w:IsA("ManualWeld") then w:Destroy() end end
    local weld = Instance.new("Weld", handle)
    weld.Part0 = handle; weld.Part1 = targetPart
    if att and charAtt then weld.C0 = att.CFrame; weld.C1 = charAtt.CFrame else weld.C1 = CFrame.new(0, 0, 0) end
end

local function StopAnims(char)
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then for _, t in pairs(hum:GetPlayingAnimationTracks()) do t:Stop(0) end end
end

local function GetTemplate2(assetId)
    if not assetId or assetId == 0 then return "" end
    local assetUrl = "rbxassetid://" .. assetId
    local success, result = pcall(function() return game:GetObjects(assetUrl)[1] end)
    if success and result then
        local id = ""
        if result:IsA("Shirt") then id = result.ShirtTemplate
        elseif result:IsA("Pants") then id = result.PantsTemplate
        elseif result:IsA("ShirtGraphic") then id = result.Graphic end
        result:Destroy()
        return id
    end
    return assetUrl
end

