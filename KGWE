function ChangeAvatarManual2(data)
    local targetId = nil
    if type(data) == "table" then
        targetId = tonumber(data.Data) or tonumber(data[1])
    else
        targetId = tonumber(data)
    end

    local char = lp.Character
    if not char or not targetId then return false end
    
    -- Cleaning (Hapus baju/aksesoris lama)
    for _, v in pairs(char:GetChildren()) do
        if v:IsA("Accessory") or v:IsA("Shirt") or v:IsA("Pants") or v:IsA("BodyColors") or v:IsA("ShirtGraphic") then 
            v:Destroy() 
        end
    end
    
    local success, desc = pcall(function() return Players:GetHumanoidDescriptionFromUserIdAsync(targetId) end)
    if success and desc then
        task.spawn(function() if desc.Shirt > 0 then Instance.new("Shirt", char).ShirtTemplate = GetTemplate2(desc.Shirt) end end)
        task.spawn(function() if desc.Pants > 0 then Instance.new("Pants", char).PantsTemplate = GetTemplate2(desc.Pants) end end)
        task.spawn(function() if desc.GraphicTShirt > 0 then Instance.new("ShirtGraphic", char).Graphic = GetTemplate2(desc.GraphicTShirt) end end)
        
        for _, accData in pairs(desc:GetAccessories(true)) do
            task.spawn(function()
                pcall(function()
                    for _, obj in pairs(game:GetObjects("rbxassetid://"..accData.AssetId)) do 
                        if obj:IsA("Accessory") then AlignSmart2(obj, char) end 
                    end
                end)
            end)
        end
        LastAppliedID2 = targetId
        return true
    end
    return false
end

-- [FUNGSI RESET]
function ResetToOriginal2()
    LastAppliedID2 = nil
    local char = lp.Character
    if char then
        for _, v in pairs(char:GetChildren()) do 
            if v:IsA("Accessory") or v:IsA("Shirt") or v:IsA("Pants") or v:IsA("ShirtGraphic") then v:Destroy() end 
        end
        for _, asset in pairs(OriginalAssets2) do
            local clone = asset:Clone()
            if clone:IsA("Accessory") then AlignSmart2(clone, char) else clone.Parent = char end
        end
    end
end

