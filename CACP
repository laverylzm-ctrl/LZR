local function ApplyToChar(char)
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    pcall(function()
        local d = hum:GetAppliedDescription()
        d.Head = tonumber(inHead.Text) or d.Head; d.Torso = tonumber(inTorso.Text) or d.Torso
        d.RightArm = tonumber(inRA.Text) or d.RightArm; d.LeftArm = tonumber(inLA.Text) or d.LeftArm
        d.RightLeg = tonumber(inRL.Text) or d.RightLeg; d.LeftLeg = tonumber(inLL.Text) or d.LeftLeg
        hum:ApplyDescriptionClientServer(d)
        
        for _, v in pairs(char:GetChildren()) do 
            if (v:IsA("Accessory") and not v:FindFirstChild("IsNebula")) or v:IsA("Shirt") or v:IsA("Pants") then v:Destroy() end 
        end
        for _, box in pairs(SlotInputs) do
            local id = tonumber(box.Text)
            if id then
                for _, obj in pairs(game:GetObjects("rbxassetid://"..id)) do
                    local clone = obj:Clone(); Instance.new("BoolValue", clone).Name = "IsNebula"
                    if clone:IsA("Accessory") then AlignSmart(clone, char) else clone.Parent = char end
                end
            end
        end
    end)
end

