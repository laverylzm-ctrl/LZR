local function LoadFile()
    if isfile(presetsFileName) then 
        local success, content = pcall(function() return readfile(presetsFileName) end)
        return success and HttpService:JSONDecode(content) or {}
    end
    return {}
end

local function WriteFile(data)
    writefile(presetsFileName, HttpService:JSONEncode(data))
end

