            -- Tampilkan kembali karakter
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") or part:IsA("Decal") then
                    part.Transparency = 0
                end
            end
            root.Transparency = 1 -- RootPart tetap harus transparan
        end
